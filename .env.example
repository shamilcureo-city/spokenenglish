# FluentMap — root env (tooling, Supabase deploy, edge-function secrets)
# Copy to `.env` and fill in. `.env` is gitignored. NONE of this is needed to run
# the science engine, the tests, or the demo /map (those use no env).

# ────────────────────────────────────────────────────────────────
# Supabase  (Dashboard → Project Settings → API)
# ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Public "anon" key — safe to expose to the browser (RLS protects data).
SUPABASE_ANON_KEY=eyJhbGciOi...

# SECRET "service_role" key — bypasses RLS. Server / seeding ONLY.
# Never ship this to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Postgres connection string (Settings → Database) — used to run migrations/seeds
# via `psql "$DATABASE_URL" -f supabase/seed.sql`.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ────────────────────────────────────────────────────────────────
# Gemini  (server-side ONLY — this is the key from the original app)
# ────────────────────────────────────────────────────────────────
# Used by the edge functions (start-session / score-*). Set it as a Supabase
# secret:  supabase secrets set GEMINI_API_KEY=...
# DO NOT put this in any VITE_ variable — it must never reach the browser.
GEMINI_API_KEY=your-google-gemini-api-key

# Security hardening (opt-in). When "true", start-session mints a single-use
# ephemeral token so the raw key never reaches the browser. Falls back to the
# verified key path if minting fails. Verify against your project before relying
# on it. Default (unset) = the verified key-in-URL path.
# GEMINI_USE_EPHEMERAL_TOKENS=true
