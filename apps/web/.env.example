# FluentMap web client env.
# Copy to `apps/web/.env`. Vite ONLY exposes variables prefixed with `VITE_`.
#
# ⚠️  Only put PUBLIC values here — anything VITE_ is bundled into the browser.
#     Never add GEMINI_API_KEY or the Supabase service_role key.
#
# Not needed for the Phase-1 demo /map (it runs on engine-generated mock data).
# Required from Phase 2 onward (accounts + live data).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
