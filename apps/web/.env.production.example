# Production env for the web build (set these in your host's env, e.g. Vercel).
# Copy to .env.production or configure in the dashboard — do NOT commit real values.

# The deployed backend (the token-proxy + recap/placement API). Without this the
# build defaults to a same-origin /api. Point it at your API host:
VITE_FUNCTIONS_URL=https://api.speakwell.app
