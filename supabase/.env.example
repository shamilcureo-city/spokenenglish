# Copy to `supabase/.env` and fill in. Used by `supabase functions serve --env-file supabase/.env`.
# (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected automatically — don't set them.)

GEMINI_API_KEY=your-google-gemini-api-key

# Optional security hardening (see supabase/functions/README.md):
# GEMINI_USE_EPHEMERAL_TOKENS=true
